{
  "name": "mealprep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/prebuild.mjs",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:status": "tsx scripts/migrate.ts --status",
    "db:seed": "tsx scripts/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "next": "14.2.15",
    "next-intl": "^3.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "pg": "^8.13.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "supabase": "^1.207.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
